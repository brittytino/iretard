<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <EditText android:id="@+id/editTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Title" />
    <EditText android:id="@+id/editMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Message" android:layout_marginTop="8dp" />
    <EditText android:id="@+id/editDelay" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Delay (seconds)" android:inputType="number" android:layout_marginTop="8dp" />
    <Button android:id="@+id/btnTriggerAction" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Set Reminder" android:layout_marginTop="12dp" />
</LinearLayout>
